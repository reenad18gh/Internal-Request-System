<odoo>

    <record id="view_internal_request_tree" model="ir.ui.view">
        <field name="name">internal.request.tree</field>
        <field name="model">internal.request</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="employee_name"/>
                <field name="request_type"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_internal_request_form" model="ir.ui.view">
        <field name="name">internal.request.form</field>
        <field name="model">internal.request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" type="object" string="Submit" states="draft"/>
                    <button name="action_approve" type="object" string="Approve" states="submitted"/>
                    <button name="action_reject" type="object" string="Reject" states="submitted"/>
                    <field name="state" widget="statusbar"/>
                </header>

                <sheet>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="employee_name"/>
                        <field name="request_type"/>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_internal_request" model="ir.actions.act_window">
        <field name="name">Internal Requests</field>
        <field name="res_model">internal.request</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_internal_root" name="Internal System"/>
    <menuitem id="menu_internal_request" name="Requests"
              parent="menu_internal_root"
              action="action_internal_request"/>

</odoo>
